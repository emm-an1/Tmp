# --- Example 9.2: Monty Hall ---
def monty_hall(trials, rng):
    car  = rng.integers(0, 3, trials)
    pick = rng.integers(0, 3, trials)
    return (car != pick).mean()

print("P(win | switch):", round(monty_hall(100_000, rng), 3))

