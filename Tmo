# --- Example 5.2: GBM simulators ---
def simulate_terminal(S0, r, sigma, T, N, rng):
    Z = rng.standard_normal(N)
    return S0 * np.exp((r - 0.5*sigma**2)*T + sigma*np.sqrt(T)*Z)

def simulate_paths(S0, r, sigma, T, steps, N, rng):
    dt = T / steps
    Z = rng.standard_normal((N, steps))
    increments = (r - 0.5*sigma**2)*dt + sigma*np.sqrt(dt)*Z
    log_paths = np.log(S0) + np.cumsum(increments, axis=1)
    return np.exp(log_paths)

paths = simulate_paths(100, 0.05, 0.2, 1.0, 252, 5, rng)
print("paths shape:", paths.shape, "| terminal prices:", paths[:, -1].round(2))

