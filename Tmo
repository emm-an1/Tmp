"""
Data loading and transformations.

Pure functions — no Streamlit imports. Caching/UI feedback (warnings, spinners)
are wrapped at the GUI layer; this module is reusable from notebooks/scripts.
"""

from __future__ import annotations

from pathlib import Path
from typing import Callable, Dict, Tuple

import io

import numpy as np
import pandas as pd


REQUIRED_COLS = {"date", "PX_LAST", "id"}


# ---------------------------------------------------------------------------
# CSV loading (long format: date, PX_LAST, id)
# ---------------------------------------------------------------------------
def _validate_and_clean(
    df: pd.DataFrame, dayfirst: bool = False
) -> Tuple[pd.DataFrame, int]:
    """
    Validate columns, parse dates, coerce numeric, drop bad rows.

    Returns (clean_df, n_dropped). Caller decides whether to warn.
    """
    missing = REQUIRED_COLS - set(df.columns)
    if missing:
        raise ValueError(
            f"CSV missing required columns: {sorted(missing)}. "
            f"Found: {list(df.columns)}"
        )
    df = df[["date", "PX_LAST", "id"]].copy()
    df["date"] = pd.to_datetime(df["date"], errors="coerce", dayfirst=dayfirst)
    df["PX_LAST"] = pd.to_numeric(df["PX_LAST"], errors="coerce")
    df["id"] = df["id"].astype(str).str.strip()
    n_before = len(df)
    df = df.dropna(subset=["date", "PX_LAST"])
    n_dropped = n_before - len(df)
    df = df.sort_values(["id", "date"]).reset_index(drop=True)
    return df, n_dropped


def load_csv(
    path: str | Path, dayfirst: bool = False
) -> Tuple[pd.DataFrame, int]:
    """
    Load a long-format CSV from disk.

    Parameters
    ----------
    path : str or Path
        Absolute or relative path to a CSV with columns date, PX_LAST, id.
    dayfirst : bool
        Set True if the date column uses D/M/YYYY (European). Default M/D/YYYY.

    Returns
    -------
    (df, n_dropped) : (pd.DataFrame, int)
    """
    raw = pd.read_csv(path)
    return _validate_and_clean(raw, dayfirst=dayfirst)


def load_csv_from_bytes(
    data: bytes, dayfirst: bool = False
) -> Tuple[pd.DataFrame, int]:
    """Same as load_csv but for an in-memory CSV (e.g. uploaded file)."""
    raw = pd.read_csv(io.BytesIO(data))
    return _validate_and_clean(raw, dayfirst=dayfirst)


# ---------------------------------------------------------------------------
# Series extraction & transforms
# ---------------------------------------------------------------------------
def get_asset_level(df: pd.DataFrame, asset_id: str) -> pd.Series:
    """Pull one asset's level (PX_LAST) series, indexed by date."""
    sub = (
        df.loc[df["id"] == asset_id, ["date", "PX_LAST"]]
        .set_index("date")["PX_LAST"]
        .sort_index()
    )
    sub = sub[~sub.index.duplicated(keep="last")]
    sub.name = asset_id
    return sub.astype(float)


TRANSFORMS: Dict[str, Callable[[pd.Series], pd.Series]] = {
    "Raw level": lambda s: s,
    "Daily return (%)": lambda s: s.pct_change() * 100.0,
    "Daily log return": lambda s: np.log(s / s.shift(1)),
    "Daily change (diff)": lambda s: s.diff(),
    "5-day return (%)": lambda s: s.pct_change(5) * 100.0,
    "20-day return (%)": lambda s: s.pct_change(20) * 100.0,
    "20-day rolling vol (ann.)": lambda s: s.pct_change().rolling(20).std()
                                            * np.sqrt(252) * 100.0,
}


def apply_transform(series: pd.Series, name: str) -> pd.Series:
    """Apply a named transform from TRANSFORMS, dropping NaNs."""
    if name not in TRANSFORMS:
        raise KeyError(f"Unknown transform: {name!r}. Choices: {list(TRANSFORMS)}")
    return TRANSFORMS[name](series).dropna()


# ---------------------------------------------------------------------------
# Sample data fallback (synthetic)
# ---------------------------------------------------------------------------
def load_sample_long() -> pd.DataFrame:
    """Synthetic long-format dataframe with realistic shocks. For demos."""
    rng = np.random.default_rng(2024)
    dates = pd.date_range("1990-01-01", "2025-12-31", freq="B")
    n = len(dates)

    spy_r = rng.normal(0.00040, 0.011, n)
    qqq_r = rng.normal(0.00050, 0.018, n)
    gold_r = rng.normal(0.00030, 0.009, n)

    gfc = (dates >= "2008-09-01") & (dates <= "2009-03-31")
    spy_r[gfc] -= 0.005
    qqq_r[gfc] -= 0.006
    covid = (dates >= "2020-02-20") & (dates <= "2020-03-23")
    spy_r[covid] -= 0.013
    qqq_r[covid] -= 0.012
    dotcom = (dates >= "2000-03-01") & (dates <= "2002-10-01")
    qqq_r[dotcom] -= 0.0035

    spy = 100 * np.exp(np.cumsum(spy_r))
    qqq = 100 * np.exp(np.cumsum(qqq_r))
    gold = 300 * np.exp(np.cumsum(gold_r))

    target = np.linspace(7.5, 4.0, n)
    y10 = np.empty(n)
    y10[0] = 7.5
    for i in range(1, n):
        y10[i] = y10[i - 1] + 0.03 * (target[i] - y10[i - 1]) + rng.normal(0, 0.06)
    y10 = np.maximum(y10, 0.1)

    frames = []
    for asset_id, vals in [("SPY", spy), ("QQQ", qqq), ("GOLD", gold), ("US10Y", y10)]:
        frames.append(pd.DataFrame({"date": dates, "PX_LAST": vals, "id": asset_id}))
    return pd.concat(frames, ignore_index=True)

