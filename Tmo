"""
Forward-path computation: given a set of analogue windows, compute how the
focus asset behaved in the days *after* each analogue ended.
"""

from __future__ import annotations

from typing import Optional, Tuple

import numpy as np
import pandas as pd


def compute_forward_paths(
    focus: pd.Series,
    matches_df: pd.DataFrame,
    horizon: int,
    mode: str = "% change",
) -> Tuple[pd.DataFrame, int]:
    """
    For each analogue, get the focus path for `horizon` days after end_date.

    Parameters
    ----------
    focus : pd.Series
        Focus asset series (any transform: levels, returns, vol).
    matches_df : pd.DataFrame
        Output of HistoricalAnalogueFinder.find_analogues().
        Needs columns: start_date, end_date.
    horizon : int
        Number of trading days forward.
    mode : "% change" | "absolute change"
        How to express the path. % change suits prices/levels;
        absolute change suits returns, yields, vol.

    Returns
    -------
    (paths_df, n_dropped)
        paths_df has shape (horizon+1, n_analogues_used). Index is days_forward.
        Columns are labeled by analogue start date.
        n_dropped counts analogues without enough forward data (or zero base).
    """
    paths: dict = {}
    dropped = 0
    for _, row in matches_df.iterrows():
        end_date = row["end_date"]
        idx = focus.index.get_indexer([end_date], method="nearest")[0]
        if idx + horizon >= len(focus):
            dropped += 1
            continue
        window = focus.iloc[idx : idx + horizon + 1].values.astype(float)
        base = window[0]
        if mode == "% change":
            if base == 0:
                dropped += 1
                continue
            normalized = (window / base - 1.0) * 100.0
        else:
            normalized = window - base
        paths[f"{row['start_date'].date()}"] = normalized

    if not paths:
        return pd.DataFrame(), dropped
    out = pd.DataFrame(paths)
    out.index.name = "days_forward"
    return out, dropped


def compute_query_forward_path(
    focus: pd.Series,
    query_end: pd.Timestamp,
    horizon: int,
    mode: str = "% change",
) -> Optional[np.ndarray]:
    """
    Realized path of the focus asset after the query window — useful
    when the query ends in the past and you want to overlay actuals.

    Returns None if there's no post-query data.
    """
    idx = focus.index.get_indexer([query_end], method="nearest")[0]
    available = len(focus) - idx - 1
    if available < 1:
        return None
    actual = min(horizon, available)
    window = focus.iloc[idx : idx + actual + 1].values.astype(float)
    base = window[0]
    if mode == "% change":
        if base == 0:
            return None
        return (window / base - 1.0) * 100.0
    return window - base


def summarize_forward_paths(paths_df: pd.DataFrame) -> dict:
    """One-line distribution summary at the horizon."""
    if paths_df.empty:
        return {}
    final = paths_df.iloc[-1]
    return {
        "n": int(len(final)),
        "median": float(final.median()),
        "mean": float(final.mean()),
        "pct_positive": float((final > 0).mean() * 100),
        "p25": float(final.quantile(0.25)),
        "p75": float(final.quantile(0.75)),
        "p10": float(final.quantile(0.10)),
        "p90": float(final.quantile(0.90)),
    }

