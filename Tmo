"""
Historical analogue finder: Euclidean distance on (optionally normalized) windows.
"""

from __future__ import annotations

from typing import Literal, Optional, Tuple, Union

import numpy as np
import pandas as pd
from numpy.lib.stride_tricks import sliding_window_view


NormMethod = Literal["zscore", "demean", "none"]


class HistoricalAnalogueFinder:
    """
    Find historical periods most similar to a query window.

    Parameters
    ----------
    series : pd.Series
        Time series of the statistic of interest (e.g. daily returns,
        monthly CPI YoY). Must have a DatetimeIndex. NaNs are dropped.
    normalize : {"zscore", "demean", "none"}, default "zscore"
        Per-window normalization applied before distance:
          - "zscore": (x - mean) / std        -> compares shape only
          - "demean": (x - mean)              -> compares level-adjusted shape
          - "none":  raw values               -> compares absolute trajectory
    """

    def __init__(self, series: pd.Series, normalize: NormMethod = "zscore"):
        if not isinstance(series, pd.Series):
            raise TypeError("series must be a pandas Series")
        if not isinstance(series.index, pd.DatetimeIndex):
            raise TypeError("series must have a DatetimeIndex")
        if normalize not in ("zscore", "demean", "none"):
            raise ValueError(f"normalize must be zscore/demean/none, got {normalize!r}")

        self.series = series.dropna().sort_index().astype(float)
        self.normalize = normalize

    # ---------- internal helpers ----------
    @staticmethod
    def _normalize_matrix(W: np.ndarray, method: NormMethod) -> np.ndarray:
        if method == "none":
            return W
        means = W.mean(axis=1, keepdims=True)
        if method == "demean":
            return W - means
        stds = W.std(axis=1, keepdims=True)
        stds = np.where(stds == 0, 1.0, stds)  # avoid div-by-zero on flat windows
        return (W - means) / stds

    def _resolve_query(
        self, query: Union[pd.Series, np.ndarray, Tuple]
    ) -> Tuple[np.ndarray, Optional[Tuple[pd.Timestamp, pd.Timestamp]]]:
        if isinstance(query, tuple) and len(query) == 2:
            sub = self.series.loc[query[0]:query[1]]
            if len(sub) < 2:
                raise ValueError("Query date range yielded fewer than 2 points")
            return sub.values.astype(float), (sub.index[0], sub.index[-1])
        if isinstance(query, pd.Series):
            arr = query.values.astype(float)
            span = (query.index[0], query.index[-1]) if isinstance(query.index, pd.DatetimeIndex) else None
            return arr, span
        arr = np.asarray(query, dtype=float).ravel()
        return arr, None

    # ---------- public API ----------
    def find_analogues(
        self,
        query: Union[pd.Series, np.ndarray, Tuple],
        top_n: int = 10,
        exclude_overlap: bool = True,
        exclude_dates: Optional[Tuple] = None,
        auto_exclude_query: bool = True,
    ) -> pd.DataFrame:
        """
        Returns a DataFrame with columns: start_date, end_date, distance, similarity
        sorted by distance ascending (best match first).
        """
        q, q_span = self._resolve_query(query)
        w = len(q)
        if w < 2:
            raise ValueError("Query window must contain at least 2 points")

        values = self.series.values
        dates = self.series.index
        n = len(values)
        if w > n:
            raise ValueError(f"Query length ({w}) > history length ({n})")

        windows = sliding_window_view(values, w)
        norm_windows = self._normalize_matrix(windows, self.normalize)
        q_norm = self._normalize_matrix(q.reshape(1, -1), self.normalize).ravel()

        diffs = norm_windows - q_norm
        distances = np.sqrt((diffs ** 2).sum(axis=1))

        starts = dates[: n - w + 1]
        ends = dates[w - 1 :]

        df = pd.DataFrame(
            {"start_date": starts, "end_date": ends, "distance": distances}
        )

        excludes = []
        if exclude_dates is not None:
            excludes.append((pd.Timestamp(exclude_dates[0]), pd.Timestamp(exclude_dates[1])))
        if auto_exclude_query and q_span is not None:
            excludes.append((pd.Timestamp(q_span[0]), pd.Timestamp(q_span[1])))
        for ex_start, ex_end in excludes:
            mask = ~((df["end_date"] >= ex_start) & (df["start_date"] <= ex_end))
            df = df[mask]

        df = df.sort_values("distance", kind="mergesort").reset_index(drop=True)

        if exclude_overlap:
            kept = []
            kept_ranges: list[Tuple[pd.Timestamp, pd.Timestamp]] = []
            for row in df.itertuples(index=False):
                overlap = any(
                    not (row.end_date < s or row.start_date > e)
                    for s, e in kept_ranges
                )
                if overlap:
                    continue
                kept.append(row)
                kept_ranges.append((row.start_date, row.end_date))
                if len(kept) >= top_n:
                    break
            df = pd.DataFrame(kept)
        else:
            df = df.head(top_n).copy()

        df["similarity"] = 1.0 / (1.0 + df["distance"].to_numpy())
        return df.reset_index(drop=True)

    def get_window_values(
        self, start: pd.Timestamp, end: pd.Timestamp
    ) -> pd.Series:
        return self.series.loc[start:end]

