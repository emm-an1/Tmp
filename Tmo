# --- Example 5.6: Asian call (payoff on the average price) ---
def mc_asian_call(S, K, T, r, sigma, steps, N, rng):
    paths = simulate_paths(S, r, sigma, T, steps, N, rng)
    avg = paths.mean(axis=1)
    payoff = np.exp(-r*T)*np.maximum(avg - K, 0.0)
    return payoff.mean(), payoff.std(ddof=1)/np.sqrt(N)

