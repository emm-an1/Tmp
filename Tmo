"""
Project configuration loader.

The default config lives at <project_root>/config/default.yaml.
Callers can also pass a custom path.
"""

from __future__ import annotations

from pathlib import Path
from typing import Any, Dict, Optional

import yaml


def get_project_root() -> Path:
    """
    Walk up from this file until we find pyproject.toml.
    Falls back to two levels up (src/analogue/config.py -> project root).
    """
    here = Path(__file__).resolve()
    for parent in here.parents:
        if (parent / "pyproject.toml").exists():
            return parent
    return here.parents[2]


def load_config(path: Optional[str | Path] = None) -> Dict[str, Any]:
    """
    Load YAML config. If `path` is None, loads <project_root>/config/default.yaml.

    Returns a plain dict. Missing file -> raises FileNotFoundError with a
    helpful message rather than silently returning empty defaults.
    """
    if path is None:
        path = get_project_root() / "config" / "default.yaml"
    path = Path(path)
    if not path.exists():
        raise FileNotFoundError(
            f"Config file not found: {path}\n"
            "Create it or pass an explicit path to load_config()."
        )
    with path.open("r", encoding="utf-8") as f:
        cfg = yaml.safe_load(f) or {}
    return cfg


