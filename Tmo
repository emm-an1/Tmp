# --- Example 5.3: European call, Monte Carlo vs Black-Scholes ---
from scipy.stats import norm

def bs_call(S, K, T, r, sigma):
    d1 = (np.log(S/K) + (r + 0.5*sigma**2)*T) / (sigma*np.sqrt(T))
    d2 = d1 - sigma*np.sqrt(T)
    return S*norm.cdf(d1) - K*np.exp(-r*T)*norm.cdf(d2)

def mc_call(S, K, T, r, sigma, N, rng):
    ST = simulate_terminal(S, r, sigma, T, N, rng)
    payoff = np.exp(-r*T) * np.maximum(ST - K, 0.0)
    return payoff.mean(), payoff.std(ddof=1)/np.sqrt(N)

S, K, T, r, sigma = 100, 105, 1.0, 0.05, 0.20
analytic = bs_call(S, K, T, r, sigma)
price, se = mc_call(S, K, T, r, sigma, 1_000_000, rng)
print(f"Black-Scholes : {analytic:.4f}")
print(f"Monte Carlo   : {price:.4f}  (95% CI ±{1.96*se:.4f})")

