# --- Example 5.5: antithetic & control variates ---
def mc_call_antithetic(S, K, T, r, sigma, N, rng):
    Zh = rng.standard_normal(N // 2)
    def payoff(z):
        ST = S*np.exp((r - 0.5*sigma**2)*T + sigma*np.sqrt(T)*z)
        return np.exp(-r*T)*np.maximum(ST - K, 0.0)
    pooled = 0.5*(payoff(Zh) + payoff(-Zh))
    return pooled.mean(), pooled.std(ddof=1)/np.sqrt(N // 2)

def mc_call_control(S, K, T, r, sigma, N, rng):
    Z = rng.standard_normal(N)
    ST = S*np.exp((r - 0.5*sigma**2)*T + sigma*np.sqrt(T)*Z)
    Y  = np.exp(-r*T)*np.maximum(ST - K, 0.0)
    Xc = ST
    c  = np.cov(Y, Xc, ddof=1)[0, 1] / np.var(Xc, ddof=1)
    Yc = Y - c*(Xc - S*np.exp(r*T))
    return Yc.mean(), Yc.std(ddof=1)/np.sqrt(N)

_, se_plain = mc_call(S, K, T, r, sigma, 1_000_000, rng)
_, se_anti  = mc_call_antithetic(S, K, T, r, sigma, 1_000_000, rng)
_, se_ctrl  = mc_call_control(S, K, T, r, sigma, 1_000_000, rng)
print(f"plain SE   : {se_plain:.5f}")
print(f"antithetic : {se_anti:.5f}   (variance reduction x{(se_plain/se_anti)**2:.2f})")
print(f"control    : {se_ctrl:.5f}   (variance reduction x{(se_plain/se_ctrl)**2:.2f})")

