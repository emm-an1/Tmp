"""
Plotly figure builders. Pure functions returning go.Figure — usable from
both the Streamlit app and notebooks.
"""

from __future__ import annotations

from typing import Optional, Tuple

import numpy as np
import pandas as pd
import plotly.graph_objects as go


QUERY_COLOR = "rgba(50,120,255,0.28)"
MATCH_COLOR = "rgba(230,90,60,0.20)"


def _add_shaded_regions(fig: go.Figure, df: pd.DataFrame, color: str) -> None:
    for _, row in df.iterrows():
        fig.add_vrect(
            x0=row["start_date"], x1=row["end_date"],
            fillcolor=color, line_width=0, layer="below",
        )


def _add_query_band(fig: go.Figure, start, end) -> None:
    fig.add_vrect(
        x0=start, x1=end,
        fillcolor=QUERY_COLOR, line_width=0, layer="below",
        annotation_text="Query", annotation_position="top left",
        annotation_font=dict(size=11, color="#1f3d99"),
    )


# ---------------------------------------------------------------------------
# Panel 1: focus asset
# ---------------------------------------------------------------------------
def make_focus_panel(
    focus_series: pd.Series,
    focus_label: str,
    matches: Optional[pd.DataFrame] = None,
    query_range: Optional[Tuple] = None,
    height: int = 380,
) -> go.Figure:
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=focus_series.index, y=focus_series.values,
        mode="lines", name=focus_label,
        line=dict(color="#1f77b4", width=1.3),
        hovertemplate="%{x|%Y-%m-%d}<br>%{y:.4f}<extra></extra>",
    ))
    if matches is not None and len(matches):
        _add_shaded_regions(fig, matches, MATCH_COLOR)
    if query_range is not None:
        _add_query_band(fig, query_range[0], query_range[1])
    fig.update_layout(
        title=f"Panel 1 — Focus asset: {focus_label}",
        height=height, margin=dict(l=20, r=20, t=50, b=20),
        hovermode="x unified", showlegend=False,
    )
    return fig


# ---------------------------------------------------------------------------
# Panel 2: similarity series
# ---------------------------------------------------------------------------
def make_similarity_panel(
    similarity_series: pd.Series,
    similarity_label: str,
    matches: Optional[pd.DataFrame] = None,
    query_range: Optional[Tuple] = None,
    height: int = 320,
) -> go.Figure:
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=similarity_series.index, y=similarity_series.values,
        mode="lines", name=similarity_label,
        line=dict(color="#444", width=1.0),
        hovertemplate="%{x|%Y-%m-%d}<br>%{y:.4f}<extra></extra>",
    ))
    if matches is not None and len(matches):
        _add_shaded_regions(fig, matches, MATCH_COLOR)
    if query_range is not None:
        _add_query_band(fig, query_range[0], query_range[1])
    fig.update_layout(
        title=f"Panel 2 — Similarity series: {similarity_label}",
        height=height, margin=dict(l=20, r=20, t=50, b=20),
        hovermode="x unified", showlegend=False,
    )
    return fig


# ---------------------------------------------------------------------------
# Panel 3: forward paths
# ---------------------------------------------------------------------------
def make_forward_panel(
    paths_df: pd.DataFrame,
    focus_label: str,
    horizon: int,
    mode: str = "% change",
    realized: Optional[np.ndarray] = None,
    height: int = 420,
) -> go.Figure:
    """
    `paths_df` from compute_forward_paths.
    `realized` from compute_query_forward_path (optional).
    """
    if mode == "% change":
        y_axis_title = f"% change in {focus_label} from analogue end"
        suffix = "%"
    else:
        y_axis_title = f"Change in {focus_label} from analogue end"
        suffix = ""

    fig = go.Figure()
    if paths_df.empty:
        fig.update_layout(
            title="No analogues with sufficient forward data",
            height=height,
        )
        return fig

    x_idx = list(paths_df.index)

    # Individual analogue paths
    for col in paths_df.columns:
        fig.add_trace(go.Scatter(
            x=x_idx, y=paths_df[col].values, mode="lines",
            line=dict(color="rgba(140,140,140,0.45)", width=0.8),
            name=col, hoverinfo="skip", showlegend=False,
        ))

    # Percentile bands
    p10 = paths_df.quantile(0.10, axis=1)
    p25 = paths_df.quantile(0.25, axis=1)
    p50 = paths_df.median(axis=1)
    p75 = paths_df.quantile(0.75, axis=1)
    p90 = paths_df.quantile(0.90, axis=1)

    fig.add_trace(go.Scatter(
        x=x_idx + x_idx[::-1],
        y=list(p10.values) + list(p90.values[::-1]),
        fill="toself", fillcolor="rgba(230,90,60,0.10)",
        line=dict(width=0), hoverinfo="skip", name="10–90 pct",
    ))
    fig.add_trace(go.Scatter(
        x=x_idx + x_idx[::-1],
        y=list(p25.values) + list(p75.values[::-1]),
        fill="toself", fillcolor="rgba(230,90,60,0.22)",
        line=dict(width=0), hoverinfo="skip", name="25–75 pct",
    ))
    fig.add_trace(go.Scatter(
        x=x_idx, y=p50.values, mode="lines",
        line=dict(color="#c0392b", width=2.6), name="Median path",
        hovertemplate="day %{x}<br>median: %{y:.2f}" + suffix + "<extra></extra>",
    ))
    fig.add_hline(y=0, line_dash="dot", line_color="#888")

    if realized is not None and len(realized) > 1:
        fig.add_trace(go.Scatter(
            x=list(range(len(realized))), y=realized, mode="lines",
            line=dict(color="#1f77b4", width=2.6, dash="dash"),
            name="Realized (post-query)",
            hovertemplate="day %{x}<br>realized: %{y:.2f}" + suffix + "<extra></extra>",
        ))

    fig.update_layout(
        title=f"Panel 3 — What tended to happen next, {horizon} trading days after analogue",
        xaxis_title="Trading days after analogue end",
        yaxis_title=y_axis_title,
        height=height, margin=dict(l=20, r=20, t=50, b=40),
        hovermode="x unified",
        legend=dict(orientation="h", yanchor="bottom", y=1.02, x=0),
    )
    return fig
