# --- Example 9.1: birthday problem ---
def birthday_sim(n_people, trials, rng):
    hits = 0
    for _ in range(trials):
        days = rng.integers(0, 365, n_people)
        if len(np.unique(days)) < n_people:
            hits += 1
    return hits / trials

